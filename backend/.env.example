# VibeSkool Backend — Environment Variables
# Copy this file to .env and fill in your values

NODE_ENV=development
PORT=4000

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# PostgreSQL (uncomment when ready to connect a real DB)
# DATABASE_URL=postgresql://user:password@localhost:5432/vibeskool

# Session secret (generate a random string)
SESSION_SECRET=change-this-to-a-random-secret-string
